# App
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:5173
API_BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/unimate
POSTGRES_DB=unimate
POSTGRES_USER=user
POSTGRES_PASSWORD=your-secure-password-here

# Auth
JWT_SECRET=change-me-use-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Local Ollama default
MODEL_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_KEEP_ALIVE=30m
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSION=1024
DEMO_MODE=false

# Crawler
CRAWL_USER_AGENT=UniMate/1.0 (+https://example.com)
CRAWL_MAX_PAGES=80
CRAWL_REQUEST_TIMEOUT_SECONDS=20
CRAWL_RATE_LIMIT_SECONDS=2
CRAWL_REQUIRE_APPROVAL=true

# Optional Redis
REDIS_URL=redis://localhost:6379/0
